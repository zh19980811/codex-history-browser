<html>
<head>
  <title>Codex History Migration</title>
  <hta:application id="app" border="thin" caption="yes" sysmenu="yes" showintaskbar="yes" singleinstance="yes" />
  <style>
    body { font-family: Segoe UI, Arial; background: #f5f5f5; margin: 20px; }
    .card { background: #fff; padding: 16px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    h1 { font-size: 18px; margin: 0 0 12px 0; }
    button { padding: 10px 16px; margin-right: 8px; }
    .note { color: #555; margin-top: 12px; font-size: 12px; }
  </style>
</head>
<body>
  <div class="card">
    <h1>Codex History Migration</h1>
    <button onclick="runExport()">Export (source)</button>
    <button onclick="runImport()">Import (target)</button>
    <div class="note">Closes Codex before import. Uses %USERPROFILE%\.codex</div>
  </div>

<script>
  function runExport(){
    var shell = new ActiveXObject('WScript.Shell');
    shell.Run('cmd /c "' + location.pathname.replace(/%20/g,' ') + '"', 0, false);
    shell.Run('cmd /c "' + getDir() + 'export.cmd"', 1, false);
  }
  function runImport(){
    var shell = new ActiveXObject('WScript.Shell');
    shell.Run('cmd /c "' + getDir() + 'import.cmd"', 1, false);
  }
  function getDir(){
    var path = unescape(location.pathname);
    if (path.startsWith('/')) path = path.substring(1);
    return path.substring(0, path.lastIndexOf('/')+1).replace(/\//g,'\\');
  }
</script>
</body>
</html>
